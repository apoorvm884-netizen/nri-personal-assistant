# === Server-side (Vercel production) ===
# Set this in Vercel dashboard: Project Settings > Environment Variables
# DEEPSEEK_API_KEY=sk-your-api-key-here

# === Client-side (local development only) ===
# Used for direct AI API calls when running without Vercel dev server.
# Create a .env.local file with this variable for local dev.
# VITE_DEEPSEEK_API_KEY=sk-your-api-key-here

# Optional: override the model name (defaults to deepseek-chat)
# VITE_DEEPSEEK_MODEL=deepseek-chat
